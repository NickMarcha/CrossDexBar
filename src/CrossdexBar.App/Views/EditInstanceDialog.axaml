<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrossdexBar.App.ViewModels"
        x:Class="CrossdexBar.App.Views.EditInstanceDialog"
        x:DataType="vm:EditInstanceDialogViewModel"
        Title="Edit account"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock Text="{Binding ProviderDisplayName}" FontSize="11" Opacity="0.6" />

    <StackPanel Spacing="4">
      <TextBlock Text="Label" />
      <TextBox Text="{Binding Label}" />
    </StackPanel>

    <ItemsControl ItemsSource="{Binding Fields}">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:SettingFieldViewModel">
          <StackPanel Spacing="4" Margin="0,0,0,6">
            <TextBlock Text="{Binding Label}" />
            <TextBox Text="{Binding Value}" PlaceholderText="{Binding Placeholder}" />
          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
      <Button Content="Cancel" Click="OnCancelClicked" />
      <Button Content="Save" Click="OnSaveClicked" IsDefault="True" />
    </StackPanel>
  </StackPanel>
</Window>

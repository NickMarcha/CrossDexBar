<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrossdexBar.App.ViewModels"
        x:Class="CrossdexBar.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="CrossdexBar Settings"
        Width="480" Height="420"
        WindowStartupLocation="CenterScreen">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="Refresh every (seconds)" VerticalAlignment="Center" />
      <ComboBox ItemsSource="{Binding RefreshIntervalOptions}" SelectedItem="{Binding RefreshIntervalSeconds}" Width="100" />
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Open config file" Command="{Binding OpenConfigFileCommand}" />
      <Button Content="Add account..." Command="{Binding AddAccountCommand}" />
      <Button Content="Save" Click="OnSaveClicked" IsDefault="True" />
    </StackPanel>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Instances}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ProviderInstanceRowViewModel">
            <Border Padding="8" Margin="0,0,0,6" CornerRadius="4" Background="#14000000">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProviderDisplayName}" FontSize="11" Opacity="0.6" />
                  <TextBox Text="{Binding Label}" />
                </StackPanel>
                <Button Grid.Column="2" Content="Edit..." Click="OnEditClicked" Tag="{Binding}" VerticalAlignment="Center" Margin="0,0,4,0" />
                <Button Grid.Column="3" Content="Remove" Click="OnRemoveClicked" Tag="{Binding}" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
